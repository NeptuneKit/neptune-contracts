{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NeptuneKit/neptune-contracts/schemas/bus-envelope.schema.json",
  "title": "BusEnvelope",
  "type": "object",
  "description": "CLI -> client bus envelope.",
  "required": ["requestId", "direction", "kind", "command", "timestamp"],
  "properties": {
    "requestId": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": ["cli_to_client"]
    },
    "kind": {
      "type": "string",
      "enum": ["command"]
    },
    "command": {
      "type": "string"
    },
    "target": {
      "$ref": "./bus-target.schema.json"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
