{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NeptuneKit/neptune-contracts/schemas/bus-ack.schema.json",
  "title": "BusAck",
  "type": "object",
  "description": "Client -> CLI bus acknowledgement.",
  "required": ["status", "timestamp"],
  "properties": {
    "requestId": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": ["client_to_cli"]
    },
    "kind": {
      "type": "string",
      "enum": ["command", "event", "log"]
    },
    "command": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "message": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
